# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Application Mode: 'dev' or 'prod'
# - dev: Video streaming enabled, visualization controls available
# - prod: Processing only, no video streaming
APP_MODE=dev

# Auto-initialize default RTSP streams at startup
AUTO_INIT_STREAMS=true

# AWS REST API Gateway Configuration
AWS_INGEST_URL=https://zwgua3w3sb.execute-api.ap-south-1.amazonaws.com/prod/ingest

# Default Camera Sources (comma-separated)
# Examples:
# - Local cameras: 0, 1, 2
# - RTSP streams: rtsp://username:password@ip:port/stream
# - Mix: 0,rtsp://192.168.1.100:554/stream1,rtsp://192.168.1.101:554/stream2
DEFAULT_CAMERA_SOURCES=0

# Video Streaming Configuration (dev mode only)
VIDEO_STREAM_FPS=5
VIDEO_STREAM_QUALITY=75

# Default 6 RTSP Streams (auto-initialized if AUTO_INIT_STREAMS=true)
# Room 1-6: rtsp://64.227.185.144:8554/feed1 through feed6
